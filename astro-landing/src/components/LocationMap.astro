---
import { LOCATION_MAP } from "../data/location.js";
---

<section id="contact" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-16 animate-on-scroll fade-up">
      <p class="text-sm font-accent font-semibold uppercase tracking-[0.3em] text-primary mb-4">GET IN TOUCH</p>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-text mb-6">Visit Our Clinic</h2>
      <p class="text-text-light max-w-2xl mx-auto">{LOCATION_MAP.description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="animate-on-scroll fade-right">
        <div class="relative w-full rounded-3xl overflow-hidden bg-gray-100 border border-gray-100" style="padding-bottom: 75%">
          <iframe src={LOCATION_MAP.mapEmbed} title="PawCare Clinic Location" class="absolute inset-0 w-full h-full" style="border: 0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <div class="animate-on-scroll fade-left">
        <form class="bg-background rounded-3xl p-8 border border-gray-100 mb-6">
          <h3 class="text-xl font-heading font-bold text-text mb-6">Send us a Message</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
            <input type="text" placeholder="Your Name" class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm" id="contact-name" />
            <input type="email" placeholder="Your Email" class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm" id="contact-email" />
          </div>
          <input type="text" placeholder="Subject" class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm mb-4" id="contact-subject" />
          <textarea placeholder="Your Message" rows="4" class="form-input w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-sm mb-4 resize-none" id="contact-message"></textarea>
          <button type="submit" class="w-full px-8 py-4 bg-primary text-white text-sm font-semibold rounded-xl hover:bg-primary-dark transition-colors duration-300">Send Message</button>
        </form>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="bg-background rounded-2xl p-5 border border-gray-100 text-center">
            <div class="w-10 h-10 rounded-xl bg-secondary/15 flex items-center justify-center text-primary mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <p class="text-xs font-semibold text-text-light uppercase tracking-wider mb-1">Address</p>
            <p class="text-sm text-text font-medium">{LOCATION_MAP.address}</p>
          </div>
          <div class="bg-background rounded-2xl p-5 border border-gray-100 text-center">
            <div class="w-10 h-10 rounded-xl bg-secondary/15 flex items-center justify-center text-primary mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 013.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </div>
            <p class="text-xs font-semibold text-text-light uppercase tracking-wider mb-1">Phone</p>
            <p class="text-sm text-text font-medium">{LOCATION_MAP.phone}</p>
          </div>
          <div class="bg-background rounded-2xl p-5 border border-gray-100 text-center">
            <div class="w-10 h-10 rounded-xl bg-secondary/15 flex items-center justify-center text-primary mx-auto mb-3">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <p class="text-xs font-semibold text-text-light uppercase tracking-wider mb-1">Email</p>
            <p class="text-sm text-text font-medium">{LOCATION_MAP.email}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
