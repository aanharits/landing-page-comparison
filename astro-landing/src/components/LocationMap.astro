---
import { LOCATION_MAP } from "../data/location.js";
---

<section id="location" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    {/* Section Header */}
    <div class="mb-16 animate-on-scroll fade-up">
      <p
        class="text-xs font-semibold uppercase tracking-[0.3em] text-sagedark mb-4"
      >
        {LOCATION_MAP.subtitle}
      </p>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-onyx mb-6">
        {LOCATION_MAP.title}
      </h2>
      <p class="text-lg text-onyx/80 leading-relaxed max-w-2xl">
        {LOCATION_MAP.description}
      </p>
    </div>

    {/* Branch Selector Tabs */}
    <div
      id="branch-tabs"
      class="flex flex-wrap gap-3 mb-8 animate-on-scroll fade-up"
    >
      {
        LOCATION_MAP.branches.map((branch, index) => (
          <button
            data-index={index}
            data-map={branch.mapEmbed}
            data-address={branch.address}
            class={`branch-btn px-6 py-3 rounded-full text-sm font-semibold transition-all duration-300 ${
              index === 0
                ? "bg-onyx text-offwhite shadow-lg active-branch"
                : "bg-onyx/5 text-onyx/60 hover:bg-onyx/10 hover:text-onyx"
            }`}
          >
            {branch.name}
          </button>
        ))
      }
    </div>

    {/* Map + Info Layout */}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {/* Interactive Map — Heavy Google Maps iframe */}
      <div class="lg:col-span-2 animate-on-scroll fade-up">
        <div
          class="relative w-full rounded-4xl overflow-hidden bg-onyx/5 border border-onyx/5"
          style="padding-bottom: 60%"
        >
          <iframe
            id="main-map"
            src={LOCATION_MAP.branches[0].mapEmbed}
            title={`Map: ${LOCATION_MAP.branches[0].name}`}
            class="absolute inset-0 w-full h-full"
            style="border: 0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <p
          id="branch-address"
          class="mt-4 text-sm text-onyx/60 flex items-center gap-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4 text-sagedark"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
          </svg>
          {LOCATION_MAP.branches[0].address}
        </p>
      </div>

      {/* Info Sidebar */}
      <div class="flex flex-col gap-6 animate-on-scroll fade-left">
        {/* Contact Card */}
        <div class="bg-offwhite rounded-3xl p-8 border border-onyx/5">
          <h3 class="text-lg font-bold text-onyx mb-6">Contact Info</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-sagedark/10 flex items-center justify-center text-sagedark flex-shrink-0 mt-0.5"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-5 h-5"
                >
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
              </div>
              <div>
                <p
                  class="text-xs font-semibold text-onyx/60 uppercase tracking-wider mb-1"
                >
                  Address
                </p>
                <p class="text-sm text-onyx font-medium">
                  {LOCATION_MAP.address}
                </p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-sagedark/10 flex items-center justify-center text-sagedark flex-shrink-0 mt-0.5"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-5 h-5"
                >
                  <path
                    d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"
                  ></path>
                </svg>
              </div>
              <div>
                <p
                  class="text-xs font-semibold text-onyx/60 uppercase tracking-wider mb-1"
                >
                  Phone
                </p>
                <p class="text-sm text-onyx font-medium">
                  {LOCATION_MAP.phone}
                </p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-sagedark/10 flex items-center justify-center text-sagedark flex-shrink-0 mt-0.5"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="w-5 h-5"
                >
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </div>
              <div>
                <p
                  class="text-xs font-semibold text-onyx/60 uppercase tracking-wider mb-1"
                >
                  Email
                </p>
                <p class="text-sm text-onyx font-medium">
                  {LOCATION_MAP.email}
                </p>
              </div>
            </div>
          </div>
        </div>

        {/* Operating Hours Card */}
        <div class="bg-offwhite rounded-3xl p-8 border border-onyx/5">
          <h3 class="text-lg font-bold text-onyx mb-6">Operating Hours</h3>
          <div class="space-y-3">
            {
              LOCATION_MAP.hours.map((item) => (
                <div class="flex items-center justify-between">
                  <span class="text-sm text-onyx/80">{item.day}</span>
                  <span
                    class={`text-sm font-semibold ${
                      item.day === "Emergency" ? "text-clay" : "text-onyx"
                    }`}
                  >
                    {item.time}
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        {/* Get Directions CTA */}
        <a
          href="https://maps.google.com/?q=-6.194741,106.819561"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 px-8 py-4 bg-onyx text-offwhite text-sm font-semibold rounded-full hover:bg-onyx/80 transition-colors duration-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="w-4 h-4"
          >
            <polygon points="3,11 22,2 13,21 11,13"></polygon>
          </svg>
          Get Directions
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const branchBtns = document.querySelectorAll(".branch-btn");
    const mainMap = document.getElementById("main-map");
    const branchAddress = document.getElementById("branch-address");

    branchBtns.forEach((btn) => {
      btn.addEventListener("click", function () {
        const mapUrl = this.getAttribute("data-map");
        const address = this.getAttribute("data-address");

        if (mainMap && mapUrl) {
          mainMap.src = mapUrl;
        }

        if (branchAddress && address) {
          branchAddress.innerHTML = `
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 text-sagedark">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            ${address}
          `;
        }

        // Update active state
        branchBtns.forEach((b) => {
          b.classList.remove(
            "bg-onyx",
            "text-offwhite",
            "shadow-lg",
            "active-branch",
          );
          b.classList.add(
            "bg-onyx/5",
            "text-onyx/60",
            "hover:bg-onyx/10",
            "hover:text-onyx",
          );
        });

        this.classList.remove(
          "bg-onyx/5",
          "text-onyx/60",
          "hover:bg-onyx/10",
          "hover:text-onyx",
        );
        this.classList.add(
          "bg-onyx",
          "text-offwhite",
          "shadow-lg",
          "active-branch",
        );
      });
    });
  });
</script>
