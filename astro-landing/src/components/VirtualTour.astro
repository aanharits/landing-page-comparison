---
import { VIRTUAL_TOUR } from '../data/virtualTour.js';
---

<section id="virtual-tour" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12 animate-on-scroll fade-up">
      <p class="text-sm font-accent font-semibold uppercase tracking-[0.3em] text-primary mb-4">
        {VIRTUAL_TOUR.subtitle}
      </p>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-text mb-6">
        {VIRTUAL_TOUR.title}
      </h2>
      <p class="text-text-light max-w-2xl mx-auto">
        {VIRTUAL_TOUR.description}
      </p>
    </div>

    <!-- Main Image Display -->
    <div class="animate-on-scroll fade-up">
      <div class="rounded-3xl overflow-hidden mb-6 bg-gray-100">
        <img
          id="tour-main-image"
          src={VIRTUAL_TOUR.facilities[0].image}
          alt={VIRTUAL_TOUR.facilities[0].title}
          class="w-full h-[500px] lg:h-[600px] object-cover transition-opacity duration-300"
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </div>
      <p id="tour-main-title" class="text-xl font-heading font-bold text-text mb-2">
        {VIRTUAL_TOUR.facilities[0].title}
      </p>
      <p id="tour-main-desc" class="text-text-light">
        {VIRTUAL_TOUR.facilities[0].description}
      </p>
    </div>

    <!-- Thumbnails -->
    <div class="grid grid-cols-5 gap-4 mt-6 animate-on-scroll fade-up" style="animation-delay: 200ms">
      {VIRTUAL_TOUR.facilities.map((facility, index) => (
        <button
          class={`tour-thumb rounded-xl overflow-hidden border-2 ${index === 0 ? 'active border-primary' : 'border-transparent'}`}
          data-image={facility.image}
          data-title={facility.title}
          data-desc={facility.description}
          aria-label={`View ${facility.title}`}
        >
          <img
            src={facility.image}
            alt={facility.title}
            class="w-full h-20 sm:h-24 lg:h-28 object-cover"
            width="200"
            height="112"
            loading="lazy"
            decoding="async"
          />
        </button>
      ))}
    </div>
  </div>
</section>

<script>
  const thumbs = document.querySelectorAll('.tour-thumb');
  const mainImage = document.getElementById('tour-main-image') as HTMLImageElement;
  const mainTitle = document.getElementById('tour-main-title');
  const mainDesc = document.getElementById('tour-main-desc');

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const img = (thumb as HTMLElement).dataset.image || '';
      const title = (thumb as HTMLElement).dataset.title || '';
      const desc = (thumb as HTMLElement).dataset.desc || '';

      if (mainImage) {
        mainImage.style.opacity = '0';
        setTimeout(() => {
          mainImage.src = img;
          mainImage.alt = title;
          mainImage.style.opacity = '1';
        }, 200);
      }
      if (mainTitle) mainTitle.textContent = title;
      if (mainDesc) mainDesc.textContent = desc;

      thumbs.forEach(t => {
        t.classList.remove('active', 'border-primary');
        t.classList.add('border-transparent');
      });
      thumb.classList.add('active', 'border-primary');
      thumb.classList.remove('border-transparent');
    });
  });
</script>
