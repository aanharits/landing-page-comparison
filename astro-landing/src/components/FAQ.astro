---
import { FAQ_ITEMS } from '../data/faq_items.js';
---

<section id="faq" class="py-24 lg:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <!-- Left — Header -->
      <div class="animate-on-scroll fade-right">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-sagedark mb-4">
          FAQ
        </p>
        <h2 class="text-4xl lg:text-5xl font-extrabold text-onyx mb-6">
          Frequently Asked Questions
        </h2>
        <p class="text-onyx/70 leading-relaxed">
          Everything you need to know about our services. Can&apos;t find the answer you&apos;re looking for? Feel free to contact our friendly team.
        </p>
      </div>

      <!-- Right — Accordion -->
      <div class="animate-on-scroll fade-left" style="animation-delay: 200ms">
        {FAQ_ITEMS.map((item, index) => (
          <div class="faq-item border-b border-onyx/10">
            <button
              class="faq-toggle w-full flex items-center justify-between py-6 text-left"
              data-index={index}
            >
              <span class="text-base font-semibold text-onyx pr-4">
                {item.question}
              </span>
              <span class="faq-icon text-onyx/60 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </span>
            </button>
            <div class="faq-content">
              <p class="pb-6 text-sm text-onyx/70 leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const faqToggles = document.querySelectorAll('.faq-toggle');
  let openIndex = null;

  faqToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const index = parseInt(toggle.dataset.index);
      const faqItem = toggle.parentElement;
      const content = faqItem.querySelector('.faq-content');
      const icon = faqItem.querySelector('.faq-icon');

      if (openIndex === index) {
        // Close current
        content.classList.remove('open');
        icon.classList.remove('open');
        openIndex = null;
      } else {
        // Close previously open
        if (openIndex !== null) {
          const prevItem = document.querySelector(`.faq-toggle[data-index="${openIndex}"]`).parentElement;
          prevItem.querySelector('.faq-content').classList.remove('open');
          prevItem.querySelector('.faq-icon').classList.remove('open');
        }
        // Open current
        content.classList.add('open');
        icon.classList.add('open');
        openIndex = index;
      }
    });
  });
</script>
