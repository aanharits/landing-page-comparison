---
import { FAQ_ITEMS } from '../data/faq_items.js';
---

<section id="faq" class="py-24 lg:py-32">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      <div class="animate-on-scroll fade-right">
        <p class="text-sm font-accent font-semibold uppercase tracking-[0.3em] text-primary mb-4">FAQ</p>
        <h2 class="text-4xl lg:text-5xl font-heading font-bold text-text mb-6">Frequently Asked Questions</h2>
        <p class="text-text-light leading-relaxed">Everything you need to know about our services. Can&apos;t find the answer you&apos;re looking for? Feel free to contact our friendly team.</p>
      </div>

      <div class="animate-on-scroll fade-left" style="animation-delay: 200ms">
        {FAQ_ITEMS.map((item, index) => (
          <div class="faq-item border-b border-gray-200">
            <button class="faq-toggle w-full flex items-center justify-between py-6 text-left" data-index={index}>
              <span class="text-base font-semibold text-text pr-4">{item.question}</span>
              <span class="faq-icon text-primary flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5">
                  <line x1="12" y1="5" x2="12" y2="19" />
                  <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
              </span>
            </button>
            <div class="faq-content">
              <p class="pb-6 text-sm text-text-light leading-relaxed">{item.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const faqToggles = document.querySelectorAll('.faq-toggle');
  let openIndex: number | null = null;

  faqToggles.forEach(toggle => {
    toggle.addEventListener('click', () => {
      const index = parseInt((toggle as HTMLElement).dataset.index || '0');
      const faqItem = toggle.parentElement;
      const content = faqItem?.querySelector('.faq-content');
      const icon = faqItem?.querySelector('.faq-icon');

      if (openIndex === index) {
        content?.classList.remove('open');
        icon?.classList.remove('open');
        openIndex = null;
      } else {
        if (openIndex !== null) {
          const prevItem = document.querySelector(`.faq-toggle[data-index="${openIndex}"]`)?.parentElement;
          prevItem?.querySelector('.faq-content')?.classList.remove('open');
          prevItem?.querySelector('.faq-icon')?.classList.remove('open');
        }
        content?.classList.add('open');
        icon?.classList.add('open');
        openIndex = index;
      }
    });
  });
</script>
