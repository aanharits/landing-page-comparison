---
import { STATS, STATS_BG } from '../data/stats.js';
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <!-- Parallax Background -->
  <div
    class="parallax-bg absolute inset-0"
    style={`background-image: url('${STATS_BG}')`}
  ></div>
  <div class="absolute inset-0 bg-primary-dark/85"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12 animate-on-scroll fade-up">
      <p class="text-sm font-accent font-semibold uppercase tracking-[0.3em] text-secondary mb-4">
        BY THE NUMBERS
      </p>
      <h2 class="text-4xl lg:text-5xl font-heading font-bold text-white">
        Trusted by Thousands
      </h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      {STATS.map((stat, index) => (
        <div
          class="text-center animate-on-scroll fade-up"
          style={`animation-delay: ${index * 150}ms`}
        >
          <p class="text-5xl lg:text-6xl font-heading font-bold text-white mb-2">
            {stat.value}
          </p>
          <p class="text-sm font-accent font-medium uppercase tracking-[0.15em] text-white/60">
            {stat.label}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
